  makerId      String
  maker        User                  @relation("ApprovalMaker", fields: [makerId], references: [id])
  currentStep  Int                   @default(1)
  status       ApprovalRequestStatus @default(PENDING)
  submittedAt  DateTime              @default(now())
  dueAt        DateTime?
  completedAt  DateTime?
  notes        String?
  metadata     Json?
  decisions    ApprovalDecision[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([policyId, entityType, entityId])
  @@index([tenantId, status, submittedAt])
  @@index([makerId, status])
  @@map("approval_requests")
}

model ApprovalDecision {
  id         String               @id @default(uuid())
  requestId  String
  request    ApprovalRequest      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepId     String
  step       ApprovalPolicyStep   @relation(fields: [stepId], references: [id])
  approverId String
  approver   User                 @relation("ApprovalApprover", fields: [approverId], references: [id])
  decision   ApprovalDecisionType
  comments   String?
  createdAt  DateTime             @default(now())

  @@unique([requestId, stepId, approverId])
  @@index([approverId, createdAt])
  @@map("approval_decisions")
}

model SystemSetting {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@map("system_settings")
}

enum TallySyncDirection {
  BOTH
  PULL
  PUSH
}

enum TallySyncState {
  IDLE
  RUNNING
  SUCCESS
  FAILED
}

model TallySyncSetting {
  id                  String            @id @default(uuid())
  tenantId            String            @unique
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId           String?
  company             Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  enabled             Boolean           @default(false)
  host                String            @default("127.0.0.1")
  port                Int               @default(9000)
  companyName         String?
  direction           TallySyncDirection @default(BOTH)
  autoSync            Boolean           @default(false)
  syncIntervalSeconds Int               @default(300)
  state               TallySyncState    @default(IDLE)
  lastPulledAt        DateTime?
  lastPushedAt        DateTime?
  lastError           String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  mappings            TallySyncMapping[]
  logs                TallySyncLog[]

  @@index([companyId])
  @@map("tally_sync_settings")
}

model TallySyncMapping {
  id              String           @id @default(uuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId       String?
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  settingId       String?
  setting         TallySyncSetting? @relation(fields: [settingId], references: [id], onDelete: Cascade)
  entityType      String
  localId         String
  remoteId        String
  checksum        String?
  localUpdatedAt  DateTime?
  remoteUpdatedAt DateTime?
  lastSyncedAt    DateTime         @default(now())
  syncState       String           @default("IN_SYNC")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([tenantId, entityType, localId])
  @@unique([tenantId, entityType, remoteId])
  @@index([tenantId, entityType, syncState])
  @@index([companyId])
  @@map("tally_sync_mappings")
}

model TallySyncLog {
  id         String           @id @default(uuid())
  tenantId   String
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId  String?
  company    Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  settingId  String?
  setting    TallySyncSetting? @relation(fields: [settingId], references: [id], onDelete: Cascade)
  entityType String?
  localId    String?
  remoteId   String?
  direction  String
  action     String
  status     String
  message    String?
  payload    Json?
  createdAt  DateTime         @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, createdAt])
  @@map("tally_sync_logs")
}

model Role {
  id          String           @id @default(uuid())
  tenantId    String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String
  description String?
  isSystem    Boolean          @default(false)
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, isSystem])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      String
  code        String           @unique
  name        String
  description String?
  scope       PermissionScope  @default(TENANT)
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([module, action])
  @@map("permissions")
}

model UserRole {
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}
