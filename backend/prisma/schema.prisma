generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum PermissionScope {
  PLATFORM
  TENANT
  COMPANY
  BRANCH
}

enum AccountNature {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum DebitCredit {
  DEBIT
  CREDIT
}

enum VoucherStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum BudgetFlow {
  RECEIPT
  UTILIZATION
}

enum LedgerType {
  GENERAL
  CASH
  BANK
  CAPITAL
  CUSTOMER
  VENDOR
  TAX
  EXPENSE
  INCOME
}

enum StockMovementType {
  OPENING
  PURCHASE
  PURCHASE_RETURN
  SALE
  SALES_RETURN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  PRODUCTION_IN
  CONSUMPTION
}

enum PurchaseStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum SalesStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum ProductionOrderStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  EXITED
}

enum PayrollRunStatus {
  DRAFT
  PROCESSED
  CANCELLED
}

enum BankTransactionStatus {
  UNRECONCILED
  RECONCILED
}

enum ChequeDirection {
  ISSUED
  RECEIVED
}

enum ChequeStatus {
  PENDING
  DEPOSITED
  CLEARED
  BOUNCED
  CANCELLED
}

enum PaymentAdviceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum AuditOutcome {
  SUCCESS
  FAILURE
}

enum VoucherVerificationStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
}

enum AddonCategory {
  ACCOUNTING
  AUTOMATION
  COMMERCE
  COMPLIANCE
  INTEGRATION
  REPORTING
}

enum AddonPricingModel {
  FREE
  MONTHLY
  ANNUAL
  USAGE
}

enum AddonInstallationStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum ApiAppStatus {
  ACTIVE
  REVOKED
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  FAILING
}

enum ComplianceRuleType {
  TAX
  INVOICE
  PAYROLL
  NUMBERING
  STATUTORY
}

enum ComplianceRuleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ComplianceObligationStatus {
  PENDING
  READY
  FILED
  OVERDUE
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalDecisionType {
  APPROVED
  REJECTED
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

model Tenant {
  id                  String               @id @default(uuid())
  name                String
  slug                String               @unique
  users               User[]
  roles               Role[]
  companies           Company[]
  auditLogs           AuditLog[]
  addonInstallations  AddonInstallation[]
  marketplaceApiApps  MarketplaceApiApp[]
  marketplaceWebhooks MarketplaceWebhook[]
  complianceRules     ComplianceRule[]
  approvalPolicies    ApprovalPolicy[]
  approvalRequests    ApprovalRequest[]
  systemSettings      SystemSetting[]
  tallySyncSettings   TallySyncSetting[]
  tallySyncMappings   TallySyncMapping[]
  tallySyncLogs       TallySyncLog[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  @@map("tenants")
}

model Company {
  id                    String                 @id @default(uuid())
  tenantId              String
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                  String
  legalName             String?
  code                  String
  gstin                 String?
  pan                   String?
  email                 String?
  phone                 String?
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  country               String                 @default("India")
  pincode               String?
  financialYearStart    DateTime
  booksStartDate        DateTime
  isActive              Boolean                @default(true)
  branches              Branch[]
  costCenters           CostCenter[]
  ledgerTypeMasters     LedgerTypeMaster[]
  accountGroups         AccountGroup[]
  ledgers               Ledger[]
  vouchers              Voucher[]
  voucherTypes          VoucherType[]
  budgetTypes           BudgetType[]
  budgetGrants          BudgetGrant[]
  voucherSeries         VoucherSeries[]
  units                 Unit[]
  itemGroups            ItemGroup[]
  items                 Item[]
  vendors               Vendor[]
  purchaseInvoices      PurchaseInvoice[]
  purchaseReturns       PurchaseReturn[]
  customers             Customer[]
  salesInvoices         SalesInvoice[]
  salesReturns          SalesReturn[]
  taxRates              TaxRate[]
  billsOfMaterial       BillOfMaterial[]
  productionOrders      ProductionOrder[]
  employees             Employee[]
  payrollRuns           PayrollRun[]
  bankReconciliations   BankReconciliation[]
  cheques               Cheque[]
  paymentAdvices        PaymentAdvice[]
  auditLogs             AuditLog[]
  addonInstallations    AddonInstallation[]
  marketplaceApiApps    MarketplaceApiApp[]
  marketplaceWebhooks   MarketplaceWebhook[]
  complianceRules       ComplianceRule[]
  complianceObligations ComplianceObligation[]
  approvalPolicies      ApprovalPolicy[]
  approvalRequests      ApprovalRequest[]
  budgets               BudgetPlan[]
  tallySyncSettings     TallySyncSetting[]
  tallySyncMappings     TallySyncMapping[]
  tallySyncLogs         TallySyncLog[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("companies")
}

model BudgetType {
  id           String         @id @default(uuid())
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  budgets      BudgetPlan[]
  costCenterId String?
  costCenter   CostCenter?    @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  name         String
  code         String
  category     String         @default("ANNUAL")
  totalAmount  Decimal        @default(0) @db.Decimal(18, 2)
  isAnnual     Boolean        @default(false)
  isActive     Boolean        @default(true)
  grants       BudgetGrant[]
  vouchers     Voucher[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  @@unique([companyId, code])
  @@index([companyId, isAnnual])
  @@index([costCenterId])
  @@map("budget_types")
}

model BudgetGrant {
  id           String         @id @default(uuid())
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  budgetTypeId String
  budgetType   BudgetType     @relation(fields: [budgetTypeId], references: [id], onDelete: Cascade)
  name         String
  code         String
  amount       Decimal        @default(0) @db.Decimal(18, 2)
  isDefault    Boolean        @default(false)
  isActive     Boolean        @default(true)
  vouchers     Voucher[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  @@unique([companyId, budgetTypeId, code])
  @@index([companyId, budgetTypeId, isDefault])
  @@map("budget_grants")
}

model TaxRate {
  id           String        @id @default(uuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  code         String
  rate         Decimal       @db.Decimal(5, 2)
  cgstRate     Decimal       @default(0) @db.Decimal(5, 2)
  sgstRate     Decimal       @default(0) @db.Decimal(5, 2)
  igstRate     Decimal       @default(0) @db.Decimal(5, 2)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  itemTaxRates ItemTaxRate[]

  @@unique([companyId, code])
  @@map("tax_rates")
}

model VoucherType {
  id         String    @id @default(uuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  code       String
  category   String
  prefix     String
  nextNumber Int       @default(1)
  padding    Int       @default(5)
  suffix     String?
  isSystem   Boolean   @default(false)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@unique([companyId, code])
  @@map("voucher_types")
}

model Branch {
  id           String       @id @default(uuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  code         String
  gstin        String?
  email        String?
  phone        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String       @default("India")
  pincode      String?
  isPrimary    Boolean      @default(false)
  isActive     Boolean      @default(true)
  warehouses   Warehouse[]
  vouchers     Voucher[]
  employees    Employee[]
  payrollRuns  PayrollRun[]
  budgetLines  BudgetLine[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("branches")
}

model CostCenter {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  budgetTypes BudgetType[]
  budgets   BudgetPlan[]
  name      String
  code      String
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("cost_centers")
}

model LedgerTypeMaster {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String
  notes     String?
  isSystem  Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("ledger_type_masters")
}

model AccountGroup {
  id        String         @id @default(uuid())
  companyId String
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    AccountGroup?  @relation("AccountGroupHierarchy", fields: [parentId], references: [id])
  children  AccountGroup[] @relation("AccountGroupHierarchy")
  name      String
  code      String
  nature    AccountNature
  isSystem  Boolean        @default(false)
  ledgers   Ledger[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  @@unique([companyId, code])
  @@index([companyId, nature])
  @@map("account_groups")
}

model Ledger {
  id                  String               @id @default(uuid())
  companyId           String
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  groupId             String
  group               AccountGroup         @relation(fields: [groupId], references: [id])
  name                String
  code                String
  ledgerType          LedgerType           @default(GENERAL)
  openingBalance      Decimal              @default(0) @db.Decimal(18, 2)
  openingType         DebitCredit          @default(DEBIT)
  bankName            String?
  bankAccountNo       String?
  bankIfsc            String?
  bankBranch          String?
  gstin               String?
  pan                 String?
  email               String?
  phone               String?
  isActive            Boolean              @default(true)
  voucherLines        VoucherLine[]
  vendors             Vendor[]
  customers           Customer[]
  bankReconciliations BankReconciliation[]
  bankCheques         Cheque[]             @relation("ChequeBankLedger")
  partyCheques        Cheque[]             @relation("ChequePartyLedger")
  adviceBankLedgers   PaymentAdvice[]      @relation("AdviceBankLedger")
  adviceBeneficiaries PaymentAdvice[]      @relation("AdviceBeneficiaryLedger")
  budgetLines         BudgetLine[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("ledgers")
}

model Voucher {
  id            String               @id @default(uuid())
  companyId     String
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?              @relation(fields: [branchId], references: [id])
  budgetTypeId  String?
  budgetType    BudgetType?          @relation(fields: [budgetTypeId], references: [id], onDelete: SetNull)
  budgetGrantId String?
  budgetGrant   BudgetGrant?         @relation(fields: [budgetGrantId], references: [id], onDelete: SetNull)
  budgetFlow    BudgetFlow           @default(UTILIZATION)
  voucherType   String
  voucherNo     String
  voucherDate   DateTime
  narration     String?
  status        VoucherStatus        @default(POSTED)
  lines         VoucherLine[]
  payrollRun    PayrollRun?
  cheques       Cheque[]
  paymentAdvice PaymentAdvice?
  verification  VoucherVerification?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?

  @@unique([companyId, voucherType, voucherNo])
  @@index([companyId, voucherDate])
  @@index([companyId, budgetTypeId])
  @@index([companyId, budgetGrantId])
  @@map("vouchers")
}

model VoucherLine {
  id                 String              @id @default(uuid())
  voucherId          String
  voucher            Voucher             @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  ledgerId           String
  ledger             Ledger              @relation(fields: [ledgerId], references: [id])
  type               DebitCredit
  amount             Decimal             @db.Decimal(18, 2)
  narration          String?
  createdAt          DateTime            @default(now())
  bankReconciliation BankReconciliation?

  @@index([ledgerId])
  @@index([voucherId])
  @@map("voucher_lines")
}

model BudgetPlan {
  id          String       @id @default(uuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  budgetTypeId String?
  budgetType   BudgetType? @relation(fields: [budgetTypeId], references: [id], onDelete: SetNull)
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  name        String
  code        String
  fiscalYear  String
  periodFrom  DateTime
  periodTo    DateTime
  status      BudgetStatus @default(DRAFT)
  totalAmount Decimal      @default(0) @db.Decimal(18, 2)
  notes       String?
  lines       BudgetLine[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, code])
  @@index([companyId, status, periodFrom, periodTo])
  @@index([budgetTypeId])
  @@index([costCenterId])
  @@map("budget_plans")
}

model BudgetLine {
  id              String     @id @default(uuid())
  budgetId        String
  budget          BudgetPlan @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  ledgerId        String
  ledger          Ledger     @relation(fields: [ledgerId], references: [id])
  branchId        String?
  branch          Branch?    @relation(fields: [branchId], references: [id])
  allocatedAmount Decimal    @db.Decimal(18, 2)
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([budgetId, ledgerId, branchId])
  @@index([ledgerId])
  @@index([branchId])
  @@map("budget_lines")
}

model BankReconciliation {
  id            String                @id @default(uuid())
  companyId     String
  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankLedgerId  String
  bankLedger    Ledger                @relation(fields: [bankLedgerId], references: [id])
  voucherLineId String                @unique
  voucherLine   VoucherLine           @relation(fields: [voucherLineId], references: [id], onDelete: Cascade)
  status        BankTransactionStatus @default(RECONCILED)
  clearedDate   DateTime
  bankReference String?
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([companyId, bankLedgerId, clearedDate])
  @@map("bank_reconciliations")
}

model Cheque {
  id            String          @id @default(uuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankLedgerId  String
  bankLedger    Ledger          @relation("ChequeBankLedger", fields: [bankLedgerId], references: [id])
  partyLedgerId String?
  partyLedger   Ledger?         @relation("ChequePartyLedger", fields: [partyLedgerId], references: [id])
  voucherId     String?
  voucher       Voucher?        @relation(fields: [voucherId], references: [id])
  chequeNo      String
  chequeDate    DateTime
  amount        Decimal         @db.Decimal(18, 2)
  direction     ChequeDirection
  status        ChequeStatus    @default(PENDING)
  payeeName     String?
  clearedDate   DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([bankLedgerId, chequeNo])
  @@index([companyId, status, chequeDate])
  @@map("cheques")
}

model PaymentAdvice {
  id                  String              @id @default(uuid())
  companyId           String
  company             Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankLedgerId        String
  bankLedger          Ledger              @relation("AdviceBankLedger", fields: [bankLedgerId], references: [id])
  beneficiaryLedgerId String
  beneficiaryLedger   Ledger              @relation("AdviceBeneficiaryLedger", fields: [beneficiaryLedgerId], references: [id])
  voucherId           String?             @unique
  voucher             Voucher?            @relation(fields: [voucherId], references: [id])
  adviceNo            String
  adviceDate          DateTime
  paymentDate         DateTime
  amount              Decimal             @db.Decimal(18, 2)
  paymentMode         String
  bankReference       String?
  status              PaymentAdviceStatus @default(DRAFT)
  narration           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([companyId, adviceNo])
  @@index([companyId, status, adviceDate])
  @@map("payment_advices")
}

model Warehouse {
  id               String            @id @default(uuid())
  branchId         String
  branch           Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name             String
  code             String
  addressLine1     String?
  city             String?
  state            String?
  isPrimary        Boolean           @default(false)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  stockMovements   StockMovement[]
  purchaseInvoices PurchaseInvoice[]
  purchaseReturns  PurchaseReturn[]
  salesInvoices    SalesInvoice[]
  salesReturns     SalesReturn[]
  productionOrders ProductionOrder[]

  @@unique([branchId, code])
  @@index([branchId, isActive])
  @@map("warehouses")
}

model Unit {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  code          String
  decimalPlaces Int       @default(2)
  isActive      Boolean   @default(true)
  items         Item[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@unique([companyId, code])
  @@map("units")
}

model ItemGroup {
  id        String      @id @default(uuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    ItemGroup?  @relation("ItemGroupHierarchy", fields: [parentId], references: [id])
  children  ItemGroup[] @relation("ItemGroupHierarchy")
  name      String
  code      String
  isActive  Boolean     @default(true)
  items     Item[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?

  @@unique([companyId, code])
  @@map("item_groups")
}

model Item {
  id                     String                  @id @default(uuid())
  companyId              String
  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  groupId                String?
  group                  ItemGroup?              @relation(fields: [groupId], references: [id])
  unitId                 String
  unit                   Unit                    @relation(fields: [unitId], references: [id])
  name                   String
  code                   String
  type                   String                  @default("GOODS")
  hsnSac                 String?
  sku                    String?
  barcode                String?
  description            String?
  standardRate           Decimal                 @default(0) @db.Decimal(18, 2)
  reorderLevel           Decimal                 @default(0) @db.Decimal(18, 3)
  trackBatch             Boolean                 @default(false)
  trackSerial            Boolean                 @default(false)
  isActive               Boolean                 @default(true)
  stockMovements         StockMovement[]
  purchaseLines          PurchaseInvoiceLine[]
  purchaseReturnLines    PurchaseReturnLine[]
  salesLines             SalesInvoiceLine[]
  salesReturnLines       SalesReturnLine[]
  taxRates               ItemTaxRate[]
  billsOfMaterial        BillOfMaterial[]        @relation("BomFinishedItem")
  bomComponents          BomComponent[]          @relation("BomComponentItem")
  productionConsumptions ProductionConsumption[]
  productionOutputs      ProductionEntry[]       @relation("ProductionOutputItem")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("items")
}

model BillOfMaterial {
  id               String            @id @default(uuid())
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  finishedItemId   String
  finishedItem     Item              @relation("BomFinishedItem", fields: [finishedItemId], references: [id])
  name             String
  code             String
  version          Int               @default(1)
  outputQuantity   Decimal           @default(1) @db.Decimal(18, 3)
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  isActive         Boolean           @default(true)
  notes            String?
  components       BomComponent[]
  productionOrders ProductionOrder[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  @@unique([companyId, code, version])
  @@index([companyId, finishedItemId, isActive])
  @@map("bills_of_material")
}

model BomComponent {
  id             String         @id @default(uuid())
  bomId          String
  bom            BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  itemId         String
  item           Item           @relation("BomComponentItem", fields: [itemId], references: [id])
  quantity       Decimal        @db.Decimal(18, 3)
  wastagePercent Decimal        @default(0) @db.Decimal(5, 2)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([bomId, itemId])
  @@map("bom_components")
}

model ProductionOrder {
  id                String                @id @default(uuid())
  companyId         String
  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bomId             String
  bom               BillOfMaterial        @relation(fields: [bomId], references: [id])
  warehouseId       String
  warehouse         Warehouse             @relation(fields: [warehouseId], references: [id])
  branchId          String?
  orderNo           String
  orderDate         DateTime
  plannedStartDate  DateTime?
  plannedEndDate    DateTime?
  plannedQuantity   Decimal               @db.Decimal(18, 3)
  completedQuantity Decimal               @default(0) @db.Decimal(18, 3)
  status            ProductionOrderStatus @default(PLANNED)
  notes             String?
  entries           ProductionEntry[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?

  @@unique([companyId, orderNo])
  @@index([companyId, status, orderDate])
  @@map("production_orders")
}

model ProductionEntry {
  id                  String                  @id @default(uuid())
  productionOrderId   String
  productionOrder     ProductionOrder         @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  outputItemId        String
  outputItem          Item                    @relation("ProductionOutputItem", fields: [outputItemId], references: [id])
  entryNo             String
  productionDate      DateTime
